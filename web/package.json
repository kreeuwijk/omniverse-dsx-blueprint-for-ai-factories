{
  "name": "@nvidia/ov-dsx",
  "description": "NVIDIA Omniverse DSX Component",
  "private": false,
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@nvidia/omniverse-webrtc-streaming-library": ">=5.17.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "tsc && vite build --config vite.config.lib.ts && tsc -p tsconfig.lib.json",
    "build:lib:dev": "tsc && vite build --mode development --config vite.config.lib.ts && tsc -p tsconfig.lib.json",
    "lint": "tsc && eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
