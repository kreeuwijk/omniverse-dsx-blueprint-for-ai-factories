# Omniverse Streaming Configuration
# Copy this file to .env and adjust as needed

# Set to "true" to disable Omniverse streaming (for UI development without Kit)
VITE_DISABLE_OMNIVERSE="false"

# Server address for Kit streaming (defaults to current hostname if not set)
# For local development, use "localhost" or your machine's IP
VITE_OMNIVERSE_SERVER="localhost"

# Signaling port for WebRTC (default: 49100)
VITE_SIGNALING_PORT="49100"

# Backend chat API URL (optional, for AI features)
# VITE_CHAT_API_URL="https://portal-api.digitaltwin.jacobs.com/chat"
