{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Kit Streaming (Debug)",
            "type": "python",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/source/extensions",
                    "remoteRoot": "${workspaceFolder}/_build/linux-x86_64/release/exts"
                }
            ],
            "preLaunchTask": "kit run streaming"
        },
        {
            "name": "Backend (Debug)",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:api",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "DISABLE_AUTH_BACKEND": "true"
            }
        }
    ],
    "compounds": [
        {
            "name": "Full Stack (Kit + Web + Backend)",
            "configurations": [],
            "preLaunchTask": "Run",
            "stopAll": true
        }
    ]
}
